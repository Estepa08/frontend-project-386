  "components": {
    "schemas": {
      "Admin": {
        "type": "object",
        "required": [
          "id",
          "name",
          "email",
          "createdAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AdminCreate": {
        "type": "object",
        "required": [
          "name",
          "email",
          "password"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "AdminPatch": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        }
      },
      "Availability": {
        "type": "object",
        "required": [
          "workingHours"
        ],
        "properties": {
          "workingHours": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkingHour"
            }
          }
        }
      },
      "AvailableDates": {
        "type": "object",
        "required": [
          "dates"
        ],
        "properties": {
          "dates": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "date"
            }
          }
        }
      },
      "Meet": {
        "type": "object",
        "required": [
          "id",
          "inviteLink",
          "status",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "inviteLink": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "confirmed",
              "cancelled"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/MeetInput"
          }
        ]
      },
      "MeetInput": {
        "type": "object",
        "required": [
          "adminId",
          "userId",
          "meetingTypeId",
          "startTime",
          "endTime",
          "theme"
        ],
        "properties": {
          "adminId": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "meetingTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
